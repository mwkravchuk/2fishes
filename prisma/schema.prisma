// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GrindOption {
  whole_bean
}

enum BagSize {
  oz12
}

enum EmailJobType {
  order_confirmation
  internal_new_order
}

enum EmailJobStatus {
  pending
  processing
  sent
  failed
}

enum CheckoutRecoveryIssueStatus {
  open
  resolved
}

model Product {
  id   String @id @default(cuid())
  slug String @unique

  name        String
  description String
  origin      String
  flavorNotes String[]

  priceCents Int
  imageKey   String // S3 key for the product image
  isActive   Boolean @default(true)

  availableGrinds GrindOption[] @default([whole_bean])
  availableSizes  BagSize[]     @default([oz12])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

model Order {
  id                String @id @default(cuid())
  sourceCartId      String?
  customerEmail     String
  paymentStatus     String
  fulfillmentStatus String
  subtotalCents     Int
  shippingCents     Int
  totalCents        Int

  stripeCheckoutSessionId String    @unique
  stripePaymentIntentId   String?   @unique
  trackingCarrier         String?
  trackingNumber          String?
  shippingEmailSentAt     DateTime?

  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     OrderItem[]
  emailJobs EmailJob[]
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  productNameSnap String
  unitPriceCents  Int
  quantity        Int

  selectedGrind GrindOption
  selectedSize  BagSize

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Cart {
  id                          String    @id @default(cuid())
  sessionId                   String    @unique
  totalCents                  Int
  stripeCheckoutSessionId     String?   @unique
  stripeCheckoutSessionUrl    String?
  stripeCheckoutSessionExpire DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  items CartItem[]
}

model CartItem {
  id              String @id @default(cuid())
  cartId          String
  productId       String
  productNameSnap String
  unitPriceCents  Int
  quantity        Int

  selectedGrind GrindOption
  selectedSize  BagSize

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, selectedGrind, selectedSize])
}

model EmailJob {
  id         String         @id @default(cuid())
  orderId     String
  type       EmailJobType
  recipient  String
  status     EmailJobStatus @default(pending)
  attempts   Int            @default(0)
  lastError  String?
  sentAt     DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@index([status, createdAt])
}

model CheckoutRecoveryIssue {
  id                    String                      @id @default(cuid())
  checkoutSessionId     String                      @unique
  stripePaymentIntentId String?
  cartId                String?
  eventType             String
  lastError             String
  status                CheckoutRecoveryIssueStatus @default(open)
  recoveredOrderId      String?
  resolutionSource      String?
  resolvedAt            DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([status, createdAt])
}
